// Brock Exchange — Secure Role-Based Auth & User Management Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Core auth / RBAC entities ────────────────────────────────────────────────

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  passwordHash       String
  role               String   @default("CUSTOMER") // SUPER_ADMIN | CORE | CUSTOMER
  mustChangePassword Boolean  @default(false)
  accountStatus      String   @default("ACTIVE") // ACTIVE | SUSPENDED | FROZEN | DELETED
  lastLogin          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  core               Core?
  customer           Customer?
  auditLogs          AuditLog[]
  loginHistory       LoginHistory[]
  passwordHistory    PasswordHistory[]
  depositsCreated    Deposit[]   @relation("DepositCreatedBy")
  withdrawalsCreated Withdrawal[] @relation("WithdrawalCreatedBy")
  tradesCreated      Trade[]     @relation("TradeCreatedBy")
  walletAdjustments  WalletAdjustment[]
}

model Core {
  id              String   @id @default(cuid())
  userId          String   @unique
  invitationCode  String   @unique
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customers       Customer[]
}

model Customer {
  id                   String   @id @default(cuid())
  userId               String   @unique
  coreId               String
  invitationCode       String
  walletBalance        Float    @default(0)
  registrationTimestamp DateTime @default(now())
  kycStatus            String   @default("PENDING") // PENDING | VERIFIED | REJECTED
  accountStatus        String   @default("ACTIVE") // ACTIVE | SUSPENDED | FROZEN
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  core                 Core     @relation(fields: [coreId], references: [id])
  deposits             Deposit[]
  withdrawals          Withdrawal[]
  trades               Trade[]
}

// ─── Trading platform entities ────────────────────────────────────────────────

model Deposit {
  id          String   @id @default(cuid())
  customerId  String
  amount      Float
  currency    String   @default("USDT")
  txHash      String?
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  note        String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id])
  createdBy   User     @relation("DepositCreatedBy", fields: [createdById], references: [id])
}

model Withdrawal {
  id          String   @id @default(cuid())
  customerId  String
  amount      Float
  currency    String   @default("USDT")
  destAddress String?
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  note        String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id])
  createdBy   User     @relation("WithdrawalCreatedBy", fields: [createdById], references: [id])
}

model Trade {
  id          String   @id @default(cuid())
  customerId  String
  pair        String   @default("BTC/USDT")
  side        String   // BUY | SELL
  amount      Float    // base asset amount
  price       Float
  total       Float    // amount * price
  status      String   @default("COMPLETED") // COMPLETED | PENDING | CANCELLED
  createdById String
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id])
  createdBy   User     @relation("TradeCreatedBy", fields: [createdById], references: [id])
}

model WalletAdjustment {
  id          String   @id @default(cuid())
  customerId  String
  amount      Float    // signed: positive credit / negative debit
  reason      String
  createdById String
  createdAt   DateTime @default(now())

  createdBy   User     @relation(fields: [createdById], references: [id])
}

// ─── Security / audit ─────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  ip        String?
  device    String?
  detail    String?
  timestamp DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ip        String?
  device    String?
  success   Boolean  @default(true)
  timestamp DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
