// Brock Exchange — Secure Role-Based Auth & User Management Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Core auth / RBAC entities ────────────────────────────────────────────────

model User {
  id                 String   @id @default(cuid()) @map("_id")
  uid                String   @unique            // public-facing Brock UID (BROCK-XXXXXXXX)
  name               String
  email              String   @unique
  mobile             String?                       // mobile number (with country code)
  passwordHash       String
  role               String   @default("CUSTOMER") // SUPER_ADMIN | CORE | CUSTOMER
  mustChangePassword Boolean  @default(false)
  accountStatus      String   @default("ACTIVE") // ACTIVE | SUSPENDED | FROZEN | DELETED
  lastLogin          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  core               Core?
  customer           Customer?
  auditLogs          AuditLog[]
  loginHistory       LoginHistory[]
  passwordHistory    PasswordHistory[]
  depositsCreated    Deposit[]   @relation("DepositCreatedBy")
  withdrawalsCreated Withdrawal[] @relation("WithdrawalCreatedBy")
  tradesCreated      Trade[]     @relation("TradeCreatedBy")
  walletAdjustments  WalletAdjustment[]
  notificationsSent  Notification[] @relation("NotificationCreatedBy")
  notificationsRecv  Notification[] @relation("NotificationRecipient")
}

model Core {
  id              String   @id @default(cuid()) @map("_id")
  userId          String   @unique
  invitationCode  String   @unique
  referralCode    String   @unique                // public referral code (for agent commission tracking)
  commissionRate  Float    @default(0.1)          // 10% default commission on referred user trades
  commissionEarned Float   @default(0)            // accumulated commission in USDT
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customers       Customer[]
}

model Customer {
  id                   String   @id @default(cuid()) @map("_id")
  userId               String   @unique
  coreId               String
  invitationCode       String
  referralCode         String?                      // the agent's referral code used at registration
  walletBalance        Float    @default(0)
  frozenBalance        Float    @default(0)         // funds frozen for pending trades / holds
  registrationTimestamp DateTime @default(now())
  kycStatus            String   @default("PENDING") // PENDING | VERIFIED | REJECTED
  accountStatus        String   @default("ACTIVE") // ACTIVE | SUSPENDED | FROZEN
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  core                 Core     @relation(fields: [coreId], references: [id])
  deposits             Deposit[]
  withdrawals          Withdrawal[]
  trades               Trade[]
}

// ─── Trading platform entities ────────────────────────────────────────────────

model Deposit {
  id          String   @id @default(cuid()) @map("_id")
  customerId  String
  amount      Float
  currency    String   @default("USDT")
  txHash      String?
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  note        String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id])
  createdBy   User     @relation("DepositCreatedBy", fields: [createdById], references: [id])
}

model Withdrawal {
  id          String   @id @default(cuid()) @map("_id")
  customerId  String
  amount      Float
  currency    String   @default("USDT")
  destAddress String?
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  note        String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id])
  createdBy   User     @relation("WithdrawalCreatedBy", fields: [createdById], references: [id])
}

model Trade {
  id            String    @id @default(cuid()) @map("_id")
  customerId    String
  pair          String    @default("BTC/USDT")
  // Legacy fields kept for backwards compatibility with simple BUY/SELL trades
  side          String    // BUY | SELL (legacy) or UP | DOWN (fixed-time)
  amount        Float     // stake amount in quote currency (USDT)
  price         Float     // entry price
  total         Float     // amount * price (legacy) or stake amount
  status        String    @default("COMPLETED") // PENDING | COMPLETED | CANCELLED
  createdById   String
  createdAt     DateTime  @default(now())

  // Fixed-time trading fields
  direction     String    @default("UP")   // UP | DOWN — the user's prediction
  duration      Int       @default(0)      // duration in seconds (0 = legacy immediate trade)
  profitPercent Float     @default(0)      // potential return percentage (e.g. 20 = +20%)
  outcome       String    @default("PENDING") // PENDING | WIN | LOSS | DRAW
  payout        Float     @default(0)      // actual payout (0 if loss or pending)
  settlesAt     DateTime?                  // when the trade should be settled
  exitPrice     Float?                     // price at settlement
  updatedAt     DateTime  @updatedAt

  customer      Customer  @relation(fields: [customerId], references: [id])
  createdBy     User      @relation("TradeCreatedBy", fields: [createdById], references: [id])
}

model WalletAdjustment {
  id          String   @id @default(cuid()) @map("_id")
  customerId  String
  amount      Float    // signed: positive credit / negative debit
  reason      String
  createdById String
  createdAt   DateTime @default(now())

  createdBy   User     @relation(fields: [createdById], references: [id])
}

// ─── Security / audit ─────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid()) @map("_id")
  userId    String?
  action    String
  ip        String?
  device    String?
  detail    String?
  timestamp DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
}

model LoginHistory {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  ip        String?
  device    String?
  success   Boolean  @default(true)
  timestamp DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordHistory {
  id           String   @id @default(cuid()) @map("_id")
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid()) @map("_id")
  recipientId String
  createdById String?
  title       String
  body        String
  type        String   @default("INFO") // INFO | WARNING | SUCCESS | DEPOSIT | WITHDRAWAL | TRADE | SECURITY
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  recipient   User     @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation("NotificationCreatedBy", fields: [createdById], references: [id])
}
